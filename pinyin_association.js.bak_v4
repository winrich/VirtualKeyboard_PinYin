  "了": ["。", "，", "的", "一", "不", "是", "吗", "吧", "啊", "呢"],
  // —— "这" 的常见后续 ——
  "这": ["是", "个", "里", "样", "些", "时", "次", "是", "件", "个"],
  // —— "那" 的常见后续 ——
  "那": ["是", "个", "里", "样", "些", "时", "次", "么", "天", "边"],
