  "去": ["了", "的", "看", "年", "过", "做", "买", "哪", "来", "一"],
  // —— "来" 的常见后续 ——
  "来": ["的", "了", "是", "不", "看", "过", "说", "到", "一", "去"],
  // —— "做" 的常见后续 ——
  "做": ["的", "了", "事", "到", "不", "过", "好", "人", "出", "一"],
  // —— "会" 的常见后续 ——
  "会": ["的", "了", "不", "是", "有", "议", "场", "上", "在", "来"],
